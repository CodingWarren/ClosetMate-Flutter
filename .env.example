# ClosetMate API Keys 模板
# 复制此文件为 .env，并填入你自己的 API Key

# 和风天气 API Key（https://dev.qweather.com/）
QWEATHER_API_KEY=your_qweather_api_key_here
QWEATHER_DEFAULT_CITY=北京

# Remove.bg API Key（https://www.remove.bg/api）
REMOVEBG_API_KEY=your_removebg_api_key_here

# 百度 AI 开放平台（https://ai.baidu.com/）
BAIDU_AI_API_KEY=your_baidu_api_key_here
BAIDU_AI_SECRET_KEY=your_baidu_secret_key_here
